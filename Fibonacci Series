#include <stdio.h>

int main() {
    int n, i;
    long long fib[20];

    scanf("%d", &n);

    if (n <= 0 || n > 20) {
        printf("Invalid input! n must be between 1 and 20.\n");
        return 0;
    }

    fib[0] = 0;
    if (n > 1) fib[1] = 1;

    for (i = 2; i < n; i++) {
        fib[i] = fib[i - 1] + fib[i - 2];
    }

    printf("Fibonacci series: ");
    for (i = 0; i < n; i++) {
        printf("%lld", fib[i]);
        if (i < n - 1) printf(" ");
    }
    printf("\n");

    return 0;
}
