#include <stdio.h>
#include <stdlib.h>

int cmp(const void *a, const void *b) {
    return (*(int *)a - *(int *)b);
}

int main() {
    int n;
    scanf("%d", &n);

    int *a = (int *)malloc(n * sizeof(int));
    for (int i = 0; i < n; i++) scanf("%d", &a[i]);

    qsort(a, n, sizeof(int), cmp);

    int min = a[0], max = a[n - 1];

    int first = 1;
    for (int x = min; x <= max; x++) {
        int found = 0;
        for (int i = 0; i < n; i++) {
            if (a[i] == x) {
                found = 1;
                break;
            }
        }
        if (!found) {
            if (!first) printf(",");
            printf("%d", x);
            first = 0;
        }
    }

    free(a);
    return 0;
}
