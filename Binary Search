#include <stdio.h>

int main() {
    int arr[15];
    int target, temp;
    int low = 0, high = 14, mid = 0;
    int comparisons = 0, found_index = -1;
    int is_sorted = 1;

    // 1. Accept an unsorted array of 15 integers
    for (int i = 0; i < 15; i++) {
        scanf("%d", &arr[i]);
    }
    
    // Read the target value
    scanf("%d", &target);

    // 2. Sort the array first (using Bubble Sort)
    for (int i = 0; i < 14; i++) {
        for (int j = 0; j < 14 - i; j++) {
            if (arr[j] > arr[j + 1]) {
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }

    // Display the sorted array
    printf("Sorted array:");
    for (int i = 0; i < 15; i++) {
        printf(" %d", arr[i]);
    }
    printf("\n");

    // 3. Perform binary search and display search iterations
    printf("Binary Search Iterations:\n");
    while (low <= high) {
        comparisons++;
        mid = low + (high - low) / 2;
        
        // Print mid-point calculation logs
        printf("low=%d, high=%d, mid=%d, arr[%d]=%d\n", low, high, mid, mid, arr[mid]);
        
        if (arr[mid] == target) {
            found_index = mid;
            break;
        } else if (arr[mid] < target) {
            low = mid + 1;
        } else {
            high = mid - 1;
        }
    }

    // 4. Show final result with comparison count
    if (found_index != -1) {
        printf("Found at index %d (1-based: %d)\n", found_index, found_index + 1);
    } else {
        printf("Not found\n");
    }
    printf("Comparisons: %d\n", comparisons);

    // 5. Verify the array remains sorted post-search
    for (int i = 0; i < 14; i++) {
        if (arr[i] > arr[i + 1]) {
            is_sorted = 0;
            break;
        }
    }
    printf("Array remains sorted: %s\n", is_sorted ? "Yes" : "No");

    return 0;
}
